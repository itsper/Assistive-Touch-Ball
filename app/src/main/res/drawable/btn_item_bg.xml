<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF"> <!-- Slightly dialed back the ripple intensity for a smoother look -->

    <!-- Mask to restrict the ripple effect inside the rounded corners -->
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF"/>
            <corners android:radius="10dp"/> <!-- Balanced corner radius for smaller buttons -->
        </shape>
    </item>

    <!-- Normal state background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF"/> <!-- Subtle 10% translucent white tint -->
            <corners android:radius="10dp"/> <!-- Matches the mask radius -->
        </shape>
    </item>
</ripple>