<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <!-- STATE A: Video Player View -->
    <LinearLayout
        android:id="@+id/layout_video_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <!-- Header with Back Button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <ImageButton
                android:id="@+id/btn_video_player_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_item_bg"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="4dp"
                android:contentDescription="Back to menu" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Player"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <!-- TextureView Video Rendering Container -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/video_player_view"
            android:layout_width="match_parent"
            android:layout_height="95dp"
            android:background="#000000"
            app:surface_type="texture_view"
            app:use_controller="false"
            app:resize_mode="fit" />

        <!-- Title of current video -->
        <TextView
            android:id="@+id/txt_video_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No Video Selected"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="4dp" />

        <!-- Interactive seekbar & timers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="4dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txt_video_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#88FFFFFF"
                android:textSize="9sp" />

            <SeekBar
                android:id="@+id/video_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:thumbTint="#FFFFFF"
                android:progressTint="#FFFFFF"
                android:progressBackgroundTint="#33FFFFFF" />

            <TextView
                android:id="@+id/txt_video_total_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="#88FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Playlist View Toggle -->
            <ImageButton
                android:id="@+id/btn_video_playlist_toggle"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_playlist"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_item_bg"
                android:contentDescription="Video Playlist"
                android:padding="6dp"
                android:layout_marginEnd="12dp" />

            <!-- Play / Pause -->
            <ImageButton
                android:id="@+id/btn_video_play_pause"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_play"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_item_bg"
                android:contentDescription="Play/Pause Video"
                android:padding="7dp" />

            <!-- Skip Next -->
            <ImageButton
                android:id="@+id/btn_video_next"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_next"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_item_bg"
                android:contentDescription="Skip Next Video"
                android:padding="6dp"
                android:layout_marginStart="12dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- STATE B: Playlist View -->
    <LinearLayout
        android:id="@+id/layout_video_playlist"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <ImageButton
                android:id="@+id/btn_video_playlist_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF"
                android:background="@drawable/btn_item_bg"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="4dp"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Local Videos"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <!-- Recycler view for folders & videos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/video_playlist_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical" />

        <LinearLayout
            android:id="@+id/txt_empty_video_playlist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No local video files found"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/btn_scan_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Media"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/btn_item_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
